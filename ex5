#include <iostream>
using namespace std;

void soma(int*A, int*B, int*C, int N) {
    for (int i=0; i<N*N; i++) {
        (C+i)=(A+i)+*(B+i);
    }
}

int main() {
    int N;

    cout<<"Digite a ordem da matriz: ";
    cin>>N;

    int A[N][N], B[N][N], C[N][N];

    cout << "Digite os elementos da matriz A: ";
    for (int i=0; i<N; i++)
        for (int j=0; j<N; j++)
            cin>>A[i][j];

    cout << "Digite os elementos da matriz B: ";
    for (int i=0; i<N; i++)
        for (int j=0; j<N; j++)
            cin>>B[i][j];

    soma(&A[0][0], &B[0][0], &C[0][0], N);

    cout << "Matriz Soma: ";
    for (int i=0; i<N; i++) {
        for (int j=0; j<N; j++) {
            cout<<C[i][j] << " ";
        }
        cout<<endl;
    }

    return 0;
}
