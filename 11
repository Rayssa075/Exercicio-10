#include <iostream>
#include <cstdlib>
using namespace std;

int** alocarMatriz(int m, int n){
    int** matriz=(int*) malloc(m * sizeof(int));
    matriz[0] = (int*) malloc(m * n * sizeof(int));

    for (int i=1; i<m; i++) {
        matriz[i]=matriz[0] + i*n;
    }
    return matriz;
}

void liberarMatriz(int** matriz){
    free(matriz[0]); 
    free(matriz);   
}

int main() {
    int m, n;

    cout<<"Numero de linhas: ";
    cin>>m;
    cout<<"Numero de colunas: ";
    cin>>n;
    int** matriz=alocarMatriz(m, n);
    cout<<"Digite os elementos da matriz: ";

    for (int i=0; i<m; i++){
        for (int j=0; j<n; j++){
            cin>>matriz[i][j];
        }
    }

    cout << "Matriz: ";

    for (int i=0; i<m; i++) {
        for (int j=0; j<n; j++) {
            cout<<matriz[i][j] << " ";
        }
        cout<<endl;
    }

    liberarMatriz(matriz);
    return 0;
}
